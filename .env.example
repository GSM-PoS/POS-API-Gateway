# Server Configuration
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# Microservices URLs
AUTH_SERVICE_URL=http://localhost:3000
PAYMENT_SERVICE_URL=http://localhost:3001
CORE_SERVICE_URL=http://localhost:5005
MENU_SERVICE_URL=http://localhost:5003

# Service Timeouts (milliseconds)
AUTH_SERVICE_TIMEOUT=5000
PAYMENT_SERVICE_TIMEOUT=10000
CORE_SERVICE_TIMEOUT=10000
MENU_SERVICE_TIMEOUT=10000

# Redis Configuration (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
# REDIS_PASSWORD=your_redis_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS Configuration (REQUIRED in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info

# Production Security Notes:
# 1. Set specific CORS_ORIGINS in production (no wildcards)
# 2. Use HTTPS in production
# 3. Set up proper secret management (AWS Secrets Manager, etc.)
# 4. Configure monitoring and alerting